      {
        "pagePath": "pages/plans/index",
        "text": "计划",
        "iconPath": "static/tabbar/plan.png",
        "selectedIconPath": "static/tabbar/plan-active.png"
      },
      {
        "pagePath": "pages/statistics/index",
        "text": "统计",
        "iconPath": "static/tabbar/statistics.png",
        "selectedIconPath": "static/tabbar/statistics-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png"
      }
    ]
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "uview-plus": "uview-plus/components/u-$1/u-$1.vue"
    }
  }
